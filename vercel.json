{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "framework": "express"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": { "service": "backend" }
    },
    {
      "source": "/assets/(.*)",
      "destination": { "service": "frontend" }
    },
    {
      "source": "/logo.svg",
      "destination": { "service": "frontend" }
    },
    {
      "source": "/(analytics|login|register|my-urls|not-found)",
      "destination": {
        "service": "frontend",
        "path": "/index.html"
      }
    },
    {
      "source": "/",
      "destination": {
        "service": "frontend",
        "path": "/index.html"
      }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "backend" }
    }
  ]
}