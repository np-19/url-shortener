{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "framework": "express"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": { "service": "backend" }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(analytics|login|register|my-urls|not-found)",
      "dest": {
        "service": "frontend",
        "path": "/"
      }
    },
    {
      "src": "/",
      "dest": {
        "service": "frontend",
        "path": "/"
      }
    },
    {
      "src": "/(.*)",
      "dest": { "service": "backend" }
    }
  ]
}